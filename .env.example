# =============================================================================
# VARIABLES DE ENTORNO — Mall Digital (MallOS)
# =============================================================================
# Copiá este archivo como .env.local para desarrollo local.
# En Netlify cargá cada variable en:
#   Site settings → Environment variables → Add a variable
# =============================================================================


# ─── Firebase Client SDK (visibles en el browser — prefijo NEXT_PUBLIC_) ─────
# Obtenelas en: Firebase Console → Project settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# ─── Configuración del mall ───────────────────────────────────────────────────

# ID del tenant en Firestore (no modificar salvo migración)
NEXT_PUBLIC_DEFAULT_TENANT_ID=homa_mall

# URL pública de la app — se usa en los emails de onboarding
# Local:   http://localhost:3000
# Netlify: https://mall-digital-panel.netlify.app  (o tu dominio personalizado)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Firebase Admin SDK (solo servidor — NUNCA exponer al cliente) ────────────
# Firebase Console → Project settings → Service accounts → Generate new private key
# ⚠️ El FIREBASE_PRIVATE_KEY debe ir entre comillas dobles en Netlify
#    para preservar los saltos de línea (\n)

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ─── Email — Onboarding de comercios ─────────────────────────────────────────
# Gmail con App Password (requiere 2FA activo en la cuenta)
# Configuración: myaccount.google.com → Seguridad → Contraseñas de aplicaciones

GMAIL_USER=
GMAIL_APP_PASSWORD=
